# Supabase — API (Frontend)
VITE_SUPABASE_URL=https://straton-backend.duckdns.org
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase — DB (CLI, getrennte Datei: .env.db — siehe .env.db.example)
# Nicht in .env eintragen: @ in der URL bricht die Supabase CLI.


# mock = Demo ohne KI | openai = echte KI über Edge Functions (Secrets in Supabase)
VITE_AI_PROVIDER=openai

# Smart Instant Gemini: Schalter in Supabase `app_feature_flags.gemini_instant_enabled` (Admin oder SQL).
# Edge optional zusätzlich: Secret GEMINI_INSTANT_ENABLED=true (Fallback wenn DB-Spalte fehlt).
